{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "exclude": ["**/*+(test|spec).+(ts|tsx)", "**/node_modules/**"],
  "excludePrivate": false,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeInternal": false,
  "includeVersion": true,
  "readme": "README.md",
  "name": "Okta Unbound API Documentation",
  "navigationLinks": {
    "GitHub": "https://github.com/samdhenderson/okta-unbound"
  },
  "plugin": [],
  "theme": "default",
  "sort": ["source-order", "required-first"],
  "visibilityFilters": {
    "protected": true,
    "private": false,
    "inherited": true,
    "external": false
  },
  "searchInComments": true,
  "searchInDocuments": true,
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Background",
    "Content Script",
    "Hooks",
    "Contexts",
    "Components",
    "Utilities",
    "Types",
    "*"
  ],
  "gitRevision": "main",
  "gitRemote": "origin",
  "hideGenerator": false,
  "skipErrorChecking": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "rewrittenLink": true,
    "notDocumented": false
  },
  "blockTags": [
    "@defaultValue",
    "@deprecated",
    "@description",
    "@example",
    "@jsx",
    "@param",
    "@privateRemarks",
    "@remarks",
    "@returns",
    "@see",
    "@throws",
    "@typeParam",
    "@author",
    "@callback",
    "@category",
    "@categoryDescription",
    "@default",
    "@document",
    "@extends",
    "@augments",
    "@yields",
    "@group",
    "@groupDescription",
    "@import",
    "@inheritDoc",
    "@license",
    "@module",
    "@mergeModuleWith",
    "@prop",
    "@property",
    "@return",
    "@satisfies",
    "@since",
    "@sortStrategy",
    "@template",
    "@this",
    "@type",
    "@typedef",
    "@summary",
    "@preventInline",
    "@inlineType",
    "@preventExpand",
    "@expandType"
  ],
  "compilerOptions": {
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "kindSortOrder": [
    "Module",
    "Namespace",
    "Enum",
    "Class",
    "Interface",
    "TypeAlias",
    "Function",
    "Variable"
  ]
}
