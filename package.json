{
  "name": "okta-unbound",
  "version": "0.4.0-beta.1",
  "description": "Advanced Okta group and user management extension for administrators",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist/",
    "test": "vitest --project unit",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --project unit --coverage",
    "test:run": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,js,ts}\"",
    "prepare": "husky",
    "docs": "typedoc && node .storybook/scripts/bundle-internals.mjs",
    "docs:clean": "rm -rf .storybook/generated",
    "storybook": "node .storybook/scripts/gen-doc-pages.mjs && storybook dev -p 6006",
    "build-storybook": "npm run docs && node .storybook/scripts/gen-doc-pages.mjs && storybook build"
  },
  "keywords": [
    "okta",
    "chrome-extension",
    "identity-management",
    "user-management",
    "admin-tools",
    "iam"
  ],
  "author": "Sam Henderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shsamhenderson/okta-unbound.git"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.1",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.29",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "4.0.10",
    "@vitest/coverage-v8": "^4.0.10",
    "@vitest/ui": "^4.0.10",
    "esbuild": "^0.19.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "happy-dom": "^20.0.10",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.6",
    "msw": "^2.12.2",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "storybook": "^10.5.2",
    "storybook-addon-pseudo-states": "^10.5.2",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.10"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "bugs": {
    "url": "https://github.com/shsamhenderson/okta-unbound/issues"
  },
  "homepage": "https://github.com/shsamhenderson/okta-unbound#readme",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^3.24.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run --project unit"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
